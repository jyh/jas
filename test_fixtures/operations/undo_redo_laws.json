[
  {
    "name": "undo_redo_identity: txn + undo + redo = txn",
    "setup_svg": "two_rects.svg",
    "txns": [
      {
        "name": "move",
        "ops": [
          {"op": "select_rect", "x": 0, "y": 0, "width": 50, "height": 50, "extend": false},
          {"op": "move_selection", "dx": 10, "dy": 20}
        ]
      }
    ],
    "history": ["undo", "redo"],
    "expected_json": "undo_redo_equals_op.json"
  },
  {
    "name": "double_undo: txn1 + txn2 + undo = txn1",
    "setup_svg": "two_rects.svg",
    "txns": [
      {
        "name": "move1",
        "ops": [
          {"op": "select_rect", "x": 0, "y": 0, "width": 50, "height": 50, "extend": false},
          {"op": "move_selection", "dx": 10, "dy": 20}
        ]
      },
      {
        "name": "move2",
        "ops": [
          {"op": "select_rect", "x": 0, "y": 0, "width": 200, "height": 200, "extend": false},
          {"op": "move_selection", "dx": -5, "dy": -5}
        ]
      }
    ],
    "history": ["undo"],
    "expected_json": "double_undo_equals_op1.json"
  }
]
