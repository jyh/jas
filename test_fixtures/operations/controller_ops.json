[
  {
    "name": "copy_selection",
    "setup_svg": "two_rects.svg",
    "ops": [
      {"op": "select_rect", "x": 0, "y": 0, "width": 50, "height": 50, "extend": false},
      {"op": "copy_selection", "dx": 20, "dy": 20}
    ],
    "expected_json": "copy_selection.json"
  },
  {
    "name": "extend_select_with_shift",
    "setup_svg": "two_rects.svg",
    "ops": [
      {"op": "select_rect", "x": 0, "y": 0, "width": 50, "height": 50, "extend": false},
      {"op": "select_rect", "x": 80, "y": 0, "width": 50, "height": 50, "extend": true}
    ],
    "expected_json": "extend_select.json"
  },
  {
    "name": "lock_prevents_select",
    "setup_svg": "two_rects.svg",
    "ops": [
      {"op": "select_rect", "x": 0, "y": 0, "width": 50, "height": 50, "extend": false},
      {"op": "lock_selection"},
      {"op": "select_rect", "x": 0, "y": 0, "width": 200, "height": 200, "extend": false}
    ],
    "expected_json": "lock_prevents_select.json"
  },
  {
    "name": "unlock_restores_select",
    "setup_svg": "two_rects.svg",
    "ops": [
      {"op": "select_rect", "x": 0, "y": 0, "width": 50, "height": 50, "extend": false},
      {"op": "lock_selection"},
      {"op": "unlock_all"},
      {"op": "select_rect", "x": 0, "y": 0, "width": 200, "height": 200, "extend": false}
    ],
    "expected_json": "unlock_restores_select.json"
  },
  {
    "name": "hide_and_show_cycle",
    "setup_svg": "two_rects.svg",
    "ops": [
      {"op": "select_rect", "x": 0, "y": 0, "width": 50, "height": 50, "extend": false},
      {"op": "hide_selection"},
      {"op": "show_all"}
    ],
    "expected_json": "hide_show_cycle.json"
  },
  {
    "name": "tspan_set_attribute_mid_word",
    "setup_svg": "setup_text_hello.svg",
    "ops": [
      {"op": "set_character_attribute", "path": [0, 0], "char_start": 1, "char_end": 4, "attribute": "font_weight", "value": "bold"}
    ],
    "expected_json": "tspan_set_attribute_mid_word.json"
  },
  {
    "name": "tspan_set_attribute_whole_range",
    "setup_svg": "setup_text_hello.svg",
    "ops": [
      {"op": "set_character_attribute", "path": [0, 0], "char_start": 0, "char_end": 5, "attribute": "font_style", "value": "italic"}
    ],
    "expected_json": "tspan_set_attribute_whole_range.json"
  },
  {
    "name": "tspan_set_attribute_causes_merge",
    "setup_svg": "setup_text_ab_bold_b.svg",
    "ops": [
      {"op": "set_character_attribute", "path": [0, 0], "char_start": 0, "char_end": 2, "attribute": "font_weight", "value": "normal"}
    ],
    "expected_json": "tspan_set_attribute_causes_merge.json"
  }
]
