{
  "algorithm": "text_layout_paragraph",
  "comparison": "tolerance",
  "tolerance": 0.0001,
  "_doc": [
    "Cross-language parity fixtures for layout_with_paragraphs.",
    "Each vector specifies: content, max_width, font_size, char_width,",
    "and a list of paragraph segments. Missing per-segment fields take",
    "the ParagraphSegment::default() values defined in",
    "jas_dioxus/src/algorithms/text_layout.rs (left_indent=0,",
    "right_indent=0, first_line_indent=0, space_before=0, space_after=0,",
    "text_align='left', list_style=null, marker_gap=0,",
    "hanging_punctuation=false, word_spacing 80/100/133,",
    "last_line_align='left', hyphenate=false, hyphenate_min_word=3,",
    "hyphenate_min_before=1, hyphenate_min_after=1, hyphenate_bias=0).",
    "All ports use a deterministic measurer that returns",
    "char_count * char_width."
  ],
  "vectors": [
    {
      "name": "default_paragraph_word_wrap",
      "content": "ab cd ef",
      "max_width": 50.0,
      "font_size": 16.0,
      "char_width": 10.0,
