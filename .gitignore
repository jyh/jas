.venv
*.lock
bazel*
[xyz]

# Local editor / agent scratch
examples
transcript/
.claude
.claude/settings.local.json
.claude/projects/
.claude/.credentials.json

# OCaml / dune build artifacts that sometimes leak into the repo root
*.cmi
*.cmx
*.o

# Python bytecode
__pycache__/
*.pyc

# Editor backup / scratch files (emacs backups + auto-saves + locks, vim swap)
# (\# escapes the leading '#' so the pattern is not read as a comment)
*~
\#*\#
.\#*
*.sw[a-p]
.*.sw[a-p]

# macOS Finder metadata (do not rely on a contributor's global gitignore)
.DS_Store
**/.DS_Store

# Scratch images (e.g. article/figures/**/x.png)
x.png

# Screenshot output from capture.sh (capture.sh <AppName> screenshot.png)
screenshot.png

# NOTE: workspace/workspace.json is COMMITTED. Regenerate with:
#   python -m workspace_interpreter.compile workspace/ workspace/workspace.json
# CI enforces freshness; see scripts/check_workspace_json.sh.
